# Copy this file to .env and fill in values.
# Generate MASTER_KEY, SERVER_PEPPER, MANIFEST_SIGNING_KEY, and ADMIN_API_SECRET with:
#   ./docker/generate-secrets.sh >> .env

# Required secrets (generate with ./docker/generate-secrets.sh)
MASTER_KEY=
SERVER_PEPPER=
MANIFEST_SIGNING_KEY=
ADMIN_API_SECRET=

# Optional: separate AES-GCM key for encrypted module artifacts (*.enc).
# If omitted, MASTER_KEY is used.
# MODULE_ENCRYPTION_KEY=

# Optional overrides (docker-compose sets DB_URL automatically)
# PUBLIC_PORT=8080
# ADMIN_PORT=8081
# BASE_URL=http://localhost:8080
# Comma-separated list of allowed browser origins for the panel/admin UIs.
# If you open the UI using a different host (ex: 127.0.0.1 or a LAN IP), add it here.
# CORS_ALLOW_ORIGINS=http://localhost:3001,http://localhost:3002,http://127.0.0.1:3001,http://127.0.0.1:3002,http://localhost:5173,http://localhost:5174
# Public registration defaults to disabled in production. Set true only if you want open signups.
# ALLOW_PUBLIC_REGISTRATION=false
# STRICT_SESSION_IP=false
# CONTENT_DIR=./content
# Absolute session lifetime cap in hours. Heartbeats keep a session alive but do
# NOT extend this cap (changed 2026-06-15). Default 12.
# SESSION_TTL_HOURS=12
# A session dies this many seconds after its last heartbeat. Must exceed the
# client heartbeat interval (240s) with margin. Default 900 (15 min).
# HEARTBEAT_LIVENESS_WINDOW_SECONDS=900
# HWID trust-on-first-use: pin a device's hardware ID at /auth/verify-session and reject
# mismatches. Defaults ON when APP_ENV=production, OFF otherwise. Set explicitly to override.
# Recovery from a hardware change is an admin device reset + re-enroll (see the deploy runbook).
# HWID_TOFU_ENABLED=true
