# Base URL of the Go API server. Required in production builds — if unset, the
# app logs a loud console error and falls back to the baked default.
VITE_API_URL=https://valiant-cooperation-production.up.railway.app

# Auth transport. Leave unset (or "bearer") for the current localStorage bearer
# token. Set to "cookie" once the backend issues an httpOnly session cookie so
# the client sends credentials with every request (no token in JS).
# VITE_AUTH_MODE=cookie
