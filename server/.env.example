# Copy this file to .env and fill in values.
# Generate MASTER_KEY, SERVER_PEPPER, MANIFEST_SIGNING_KEY, and ADMIN_API_SECRET with:
#   ./docker/generate-secrets.sh >> .env

# Required secrets (generate with ./docker/generate-secrets.sh)
MASTER_KEY=
SERVER_PEPPER=
MANIFEST_SIGNING_KEY=
ADMIN_API_SECRET=

# Optional overrides (docker-compose sets DB_URL and REDIS_URL automatically)
# PUBLIC_PORT=8080
# ADMIN_PORT=8081
# BASE_URL=http://localhost:8080
# Comma-separated list of allowed browser origins for the panel/admin UIs.
# If you open the UI using a different host (ex: 127.0.0.1 or a LAN IP), add it here.
# CORS_ALLOW_ORIGINS=http://localhost:3001,http://localhost:3002,http://127.0.0.1:3001,http://127.0.0.1:3002,http://localhost:5173,http://localhost:5174
# STRICT_SESSION_IP=false
# CONTENT_DIR=./content
