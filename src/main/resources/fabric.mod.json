{
  "schemaVersion": 1,
  "id": "phantom",
  "version": "${version}",
  "name": "${displayName}",
  "description": "Core mod that loads and manages external modules through a shared API for Phantom Client",
  "authors": [
    "QuiteBoring",
    "Twiston",
    "oblongboot"
  ],
  "contact": {
    "homepage": "https://phantom.quiteboring.dev/",
    "sources": "https://github.com/PhantomScripts/Phantom"
  },
  "license": "GPL-3.0",
  "icon": "assets/phantom/icon.png",
  "environment": "*",
  "entrypoints": {
    "client": [
      {
        "adapter": "kotlin",
        "value": "org.phantom.Phantom"
      }
    ],
    "preLaunch": [
      "org.phantom.PreLaunch"
    ]
  },
  "mixins": [
    "phantom.mixins.json"
  ],
  "depends": {
    "fabric-language-kotlin": ">=$fabricKotlinVersion",
    "fabricloader": ">=$fabricLoaderVersion",
    "minecraft": "~$minecraftVersion",
    "java": ">=21",
    "fabric-api": "*"
  }
}
